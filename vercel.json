{
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" },
    { "src": "frontend/**/*.php", "use": "vercel-php@0.6.2" },
    { "src": "frontend/example_docs/*.jpg", "use": "@vercel/static" }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/",
      "destination": "/frontend/index.php"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ]
}